# ===== Backend (DERP management API) env =====
# COPY to .env and fill. NEVER commit .env (gitignored).

# Postgres (Neon serverless). Connection string từ Neon dashboard.
# ⚠ Rotate password Neon nếu đã lộ plaintext.
DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require

# Cổng backend lắng nghe
PORT=8787

# URL công khai của dashboard (để build redirect_uri Google OAuth).
# Dev: http://localhost:8787   Prod: https://dashboard.hangocthanh.io.vn
PUBLIC_URL=http://localhost:8787

# Google OAuth client (TÁI DÙNG client của oauth2-proxy/headscale).
# Nhớ thêm Authorized redirect URI: <PUBLIC_URL>/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Bí mật ký/định danh session cookie (random ≥32 ký tự)
SESSION_SECRET=dev-insecure-change-me-please-32chars

# Danh sách email được phép đăng nhập (phẩy ngăn cách). Trống = chặn tất cả ở prod.
ALLOWED_EMAILS=hangocthanh3107@gmail.com,hangocthanhperu3107@gmail.com

# Seed lần đầu: đường dẫn file derp.yaml (mount từ deployHeadscale/config/derp.yaml).
# Bỏ trống nếu seed tay.
SEED_DERP_YAML=

# Region 999 embedded (vpn2) — chỉ để hiển thị read-only trong UI.
EMBEDDED_HOSTNAME=vpn2.hangocthanh.io.vn
EMBEDDED_IPV4=165.22.12.169

# CORS origin cho dev (Vite). Trống = same-origin (prod).
CORS_ORIGIN=http://localhost:5173

# Thư mục chứa SPA build (prod phục vụ tĩnh). Trống = không phục vụ SPA.
CLIENT_DIST=

# CHỈ DEV: 'true' = bỏ qua đăng nhập Google để xem UI local. PROD luôn để 'false'.
AUTH_OPTIONAL=false

NODE_ENV=development
