{
  "name": "headscale-derp-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "DB-backed DERP node management API + dynamic derpmap.json for Headscale",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "seed": "tsx src/db/seed.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^10.0.2",
    "@fastify/static": "^8.1.1",
    "drizzle-orm": "^0.38.4",
    "fastify": "^5.2.1",
    "node-ssh": "^13.2.1",
    "postgres": "^3.4.5",
    "yaml": "^2.7.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.7",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^3.0.4"
  }
}
